<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>cafe.jeffrey</groupId>
        <artifactId>build</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>

    <artifactId>build-microscope-dmg</artifactId>

    <!--
      Packages an already-built Spring Boot fat jar (microscope.jar) into a self-contained macOS DMG
      via jpackage. It deliberately does NOT depend on or rebuild core-microscope: jpackage DMG
      packaging only runs on macOS, and macOS runners lack the proto/grpc toolchain the source build
      needs. Instead it consumes the microscope.jar produced by the regular (Linux) build and only runs
      jpackage on it — fast, and free of any build toolchain beyond the JDK itself.
    -->

    <properties>
        <finalName>microscope</finalName>
        <!-- macOS bundle versions must start with a number >= 1, but Jeffrey is pre-1.0 (0.x), so the
             release version is not a valid macOS app version. The jpackage plugin always sends some
             app version (it falls back to ${project.version} = 1.0-SNAPSHOT, which is also invalid),
             so we pin a fixed valid value here. The real release version lives on the GitHub release
             and the DMG file name. Override with -Djpackage.app.version=x.y.z (first number >= 1). -->
        <jpackage.app.version>1.0.0</jpackage.app.version>
        <!-- Clean staging directory that holds ONLY the fat jar so the jpackage input bundles nothing else. -->
        <jpackage.input.dir>${project.build.directory}/jpackage-input</jpackage.input.dir>
        <!-- Directory containing the prebuilt microscope.jar. Defaults to the local build-microscope
             output; CI overrides it with the directory the release artifact was downloaded into. -->
        <microscope.source.dir>${project.basedir}/../build-microscope/target</microscope.source.dir>
    </properties>

    <profiles>
        <!-- Activated with -Pdmg, only on macOS (jpackage DMG packaging cannot cross-compile).
             A plain "mvn package" leaves this module as an inert empty jar, like build-cli-native. -->
        <profile>
            <id>dmg</id>
            <build>
                <plugins>
                    <plugin>
                        <artifactId>maven-resources-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>stage-microscope-jar</id>
                                <phase>prepare-package</phase>
                                <goals>
                                    <goal>copy-resources</goal>
                                </goals>
                                <configuration>
                                    <outputDirectory>${jpackage.input.dir}</outputDirectory>
                                    <resources>
                                        <resource>
                                            <directory>${microscope.source.dir}</directory>
                                            <includes>
                                                <include>${finalName}.jar</include>
                                            </includes>
                                        </resource>
                                    </resources>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <plugin>
                        <groupId>org.panteleyev</groupId>
                        <artifactId>jpackage-maven-plugin</artifactId>
                        <version>1.7.4</version>
                        <executions>
                            <execution>
                                <id>build-dmg</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>jpackage</goal>
                                </goals>
                            </execution>
                        </executions>
                        <configuration>
                            <type>DMG</type>
                            <name>Jeffrey</name>
                            <appVersion>${jpackage.app.version}</appVersion>
                            <vendor>Petr Bouda</vendor>
                            <copyright>Copyright (C) 2026 Petr Bouda</copyright>
                            <input>${jpackage.input.dir}</input>
                            <mainJar>${finalName}.jar</mainJar>
                            <destination>${project.build.directory}/dist</destination>
                            <!-- Allow re-runs: jpackage fails if the output already exists. Safe because
                                 destination is inside ${project.build.directory}. -->
                            <removeDestination>true</removeDestination>
                            <!-- Bundle the running JDK itself as the runtime rather than letting
                                 jpackage jlink a trimmed image. The app is non-modular (classpath),
                                 so a full runtime guarantees Spring / DuckDB / Jackson reflective
                                 access never hits a missing module. It also sidesteps jlink, which
                                 needs the JDK's jmods/ directory, absent from the Temurin JDK that
                                 GitHub's setup-java installs ("This JDK does not contain packaged
                                 modules"). -->
                            <runtimeImage>${java.home}</runtimeImage>
                            <macPackageIdentifier>cafe.jeffrey.microscope</macPackageIdentifier>
                            <macPackageName>Jeffrey</macPackageName>
                            <!-- server.port=0 lets the OS pick a free port, so the app never collides
                                 with whatever is already on 8080 on the user's Mac. The actual bound
                                 port is reported by ctx.getWebServer().getPort(), which the
                                 ApplicationReadyEvent listener uses to open the browser. The packaged
                                 app is the only distribution that auto-opens the browser; everything
                                 else leaves jeffrey.microscope.open-browser at its false default. -->
                            <javaOptions>
                                <option>-Dserver.port=0</option>
                                <option>-Djeffrey.microscope.open-browser=true</option>
                            </javaOptions>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
